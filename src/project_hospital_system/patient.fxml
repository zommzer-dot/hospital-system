<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="700.0"
            prefWidth="1200.0"
            stylesheets="@style.css"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="project_hospital_system.PatientController">

    <children>

        <Label layoutX="420.0"
               layoutY="40.0"
               styleClass="main-title"
               text="Patient Portal"/>

        <Button layoutX="120.0"
                layoutY="180.0"
                prefHeight="50.0"
                prefWidth="250.0"
                text="View Appointments"
                onAction="#viewAppointments"/>

        <Button layoutX="450.0"
                layoutY="180.0"
                prefHeight="50.0"
                prefWidth="250.0"
                text="Search Doctor"
                onAction="#searchDoctor"/>

        <Button layoutX="780.0"
                layoutY="180.0"
                prefHeight="50.0"
                prefWidth="250.0"
                text="View Bills"
                onAction="#viewBills"/>

        <TextArea fx:id="outputArea"
                  layoutX="170.0"
                  layoutY="320.0"
                  prefHeight="250.0"
                  prefWidth="850.0"/>

    </children>

</AnchorPane>