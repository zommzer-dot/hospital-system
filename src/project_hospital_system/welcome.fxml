<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="700.0"
            prefWidth="1200.0"
            stylesheets="@style.css"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="project_hospital_system.WelcomeController">

    <children>

        <!-- Background Image -->

        <ImageView fitHeight="700.0"
                   fitWidth="1200.0"
                   layoutX="0.0"
                   layoutY="0.0"
                   opacity="0.25"
                   preserveRatio="false">

            <image>
                <Image url="@hospital.png"/>
            </image>

        </ImageView>

        <!-- Main Title -->

        <Label layoutX="120.0"
               layoutY="170.0"
               styleClass="main-title"
               text="ALEXANDRIA"/>

        <Label layoutX="120.0"
               layoutY="260.0"
               styleClass="sub-title"
               text="HOSPITAL"/>

        <!-- Buttons -->

        <Button fx:id="patientBtn"
                layoutX="160.0"
                layoutY="420.0"
                prefHeight="55.0"
                prefWidth="240.0"
                text="Patient Portal"
                onAction="#openPatientPage"/>

        <Button fx:id="adminBtn"
                layoutX="450.0"
                layoutY="420.0"
                prefHeight="55.0"
                prefWidth="240.0"
                text="System Administrator"
                onAction="#openAdminPage"/>

    </children>

</AnchorPane>